class InsertionSort{
	void sort(int arr[]) {
		for(int i=0;i<arr.length;i++) {
			int temp=arr[i];
			int j=i-1;
			while(j>=0 && arr[j]>temp) {
				arr[j+1]=arr[j];
				j--;
			}arr[j+1]=temp;
		}
	}
}



public class Main {

    public static void main(String args[]) {

        int[] arr = {3, 2, 1, 4, 5, 6, 9, 8, 1, 2};

        InsertionSort b = new InsertionSort();
        b.sort(arr);

        for (int a : arr)
            System.out.print(a + " ");
    }
}
